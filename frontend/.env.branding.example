# Optional white-label overrides for the frontend build.
# Copy to .env.branding and source before `npm run build`:
#   set -a && source .env.branding && set +a && npm run build

# App title shown when no custom logo is configured (quote values that contain spaces)
VITE_APP_TITLE="Track Maintenance"

# Login screen subtitle (quote values that contain spaces)
# VITE_LOGIN_SUBTITLE="Use the same email and password as in Traccar."

# Custom logo (place file under public/ and reference by URL path)
# VITE_LOGO_URL=/branding/logo.svg
# VITE_LOGO_ALT=My Fleet Maintenance

# Favicon path under public/
# VITE_FAVICON_URL=/favicon.ico

# Primary theme color (hex, e.g. #1a237e)
# VITE_PRIMARY_COLOR=#1a237e
