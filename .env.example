# Host networking: Traccar and MySQL are native services on the same host,
# reachable on localhost from inside the backend container.
APP_ENV=production
DATABASE_URL=mysql+pymysql://maint_user:***@127.0.0.1:3306/track_maintenance
TRACCAR_URL=http://127.0.0.1:8082
# User-facing Traccar URL for "View in Traccar" deep links (e.g. https://gps.example.com).
TRACCAR_PUBLIC_URL=https://gps.example.com
TRACCAR_ADMIN_TOKEN=
WEBHOOK_SECRET=***
BIND_HOST=127.0.0.1
BIND_PORT=8000
DUE_SOON_KM=500
DUE_SOON_DAYS=14
DUE_SOON_HOURS=50
CORS_ORIGINS=https://fleet.example.com
# Set true when the app is served over HTTPS (required for login cookies in production).
SESSION_COOKIE_SECURE=true
# Optional SMTP notifications for due/overdue maintenance.
# Recipients are resolved per vehicle from Traccar (device access / maintenance notifications).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
NOTIFICATION_COOLDOWN_HOURS=24
