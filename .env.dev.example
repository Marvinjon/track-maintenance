# Copy to .env for local development: cp .env.dev.example .env
# MySQL is started automatically via: ./scripts/dev-db.sh up

APP_ENV=development
DATABASE_URL=mysql+pymysql://maint_user:dev-password@127.0.0.1:3307/track_maintenance
TRACCAR_URL=http://localhost:8082
TRACCAR_PUBLIC_URL=
WEBHOOK_SECRET=dev-webhook-secret
BIND_HOST=127.0.0.1
BIND_PORT=8000
DUE_SOON_KM=500
DUE_SOON_DAYS=14
DUE_SOON_HOURS=50
CORS_ORIGINS=http://localhost:5173
SESSION_COOKIE_SECURE=false
